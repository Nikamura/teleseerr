{
  "name": "teleseerr",
  "version": "1.0.0",
  "description": "Telegram bot for requesting media via Seerr",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc -p web/tsconfig.json"
  },
  "keywords": [
    "telegram",
    "seerr",
    "overseerr",
    "jellyseerr",
    "sonarr",
    "radarr",
    "plex",
    "jellyfin",
    "media",
    "requests",
    "telegram-bot",
    "mini-app",
    "arr"
  ],
  "author": "karolis",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "type": "commonjs",
  "dependencies": {
    "@grammyjs/conversations": "^2.1.1",
    "dotenv": "^17.3.1",
    "grammy": "^1.41.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
