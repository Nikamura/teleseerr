TELEGRAM_BOT_TOKEN=bot123456:AAABBBCCC
SEERR_URL=http://192.168.1.100:5055
SEERR_API_KEY=your-seerr-api-key
# To find your Telegram user ID, message @userinfobot on Telegram
TELESEERR_ADMIN_USER_ID=123456789

# Optional
# TELESEERR_ADMIN_SEERR_USER_ID=1    # Auto-link admin to this Seerr user on startup (defaults to 1)
# TELESEERR_MAX_RESULTS=15
# TELESEERR_DEFAULT_4K=false
# TELESEERR_ENABLE_SPECIALS=false
# TELESEERR_DATA_DIR=./data
# TELESEERR_ANIME_SONARR_ID=          # Seerr service ID for dedicated anime Sonarr
# TELESEERR_WEBHOOK_SECRET=           # Secret token for Seerr webhook URL (e.g. openssl rand -hex 32)
# TELESEERR_MINI_APP_URL=             # HTTPS URL where Mini App is served (e.g. https://teleseerr.example.com)
# TELESEERR_MINI_APP_PORT=3000        # Port for Mini App HTTP server
# LOG_LEVEL=info
